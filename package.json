{
  "name": "luxe-media-card",
  "version": "0.1.0",
  "private": false,
  "description": "A HACS-installable Home Assistant custom card for elegant now-playing media controls.",
  "type": "module",
  "main": "dist/luxe-media-card.js",
  "files": [
    "dist",
    "README.md",
    "hacs.json",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "dev": "vite build --watch",
    "dev:demo": "vite --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "release:check": "npm test && npm run check && npm run build"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "hacs",
    "media-player"
  ],
  "author": "Atlas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://codeberg.org/AtlasCode/luxe-media-card.git"
  },
  "bugs": {
    "url": "https://codeberg.org/AtlasCode/luxe-media-card/issues"
  },
  "homepage": "https://codeberg.org/AtlasCode/luxe-media-card",
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@types/node": "^24.5.2",
    "eslint": "^9.35.0",
    "jsdom": "^27.0.0",
    "lit": "^3.3.1",
    "playwright": "^1.58.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
